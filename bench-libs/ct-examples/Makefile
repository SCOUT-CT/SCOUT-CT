PREFIX ?= /usr/local
CC = gcc
CFLAGS ?= -O0 -g
AR ?= ar
RANLIB ?= ranlib

SRC = $(wildcard src/*/*.c)
OBJ = $(SRC:.c=.o)
HEADERS = $(wildcard src/*/*.h)

lib: libexample.a

lib_so: libexample.so

tests: lib
	$(CC) -o tests tests.c  -L. -l:libexample.a -I.

$(OBJ): $(SRC)

libexample.a: $(OBJ)
	$(MAKE) create_header
	$(AR) -r $@ $^
	$(RANLIB) $@

libexample.so: $(OBJ)
	$(CC) $(CFLAGS) -shared -o $@ $^
	$(MAKE) create_header

.PHONY: clean
clean:
	rm -f $(OBJ) libexample.a libexample.so

create_header: $(HEADERS)
	@echo "/* This file is automatically generated. Do not edit. */" > example.h
	@echo "#ifndef EXAMPLES_H" >> example.h
	@echo "#define EXAMPLES_H" >> example.h
	@echo "" >> example.h
	# Concatenate all headers into one file
	@for header in $(HEADERS); do \
		cat $$header >> example.h; \
	done
	@echo "" >> example.h
	@echo "#endif" >> example.h

install_so: lib_so
	mkdir -p $(PREFIX)/lib
	install -o 0 -g 0 -m 0755 libexample.so $(PREFIX)/lib 2> /dev/null || install -m 0755 libexample.so $(PREFIX)/lib
	mkdir -p $(PREFIX)/include
	install -o 0 -g 0 -m 0644 examples.h $(PREFIX)/include 2> /dev/null || install -m 0644 examples.h $(PREFIX)/include
	ldconfig 2> /dev/null || true

install_a: lib
	mkdir -p $(PREFIX)/lib
	install -o 0 -g 0 -m 0755 libexample.a $(PREFIX)/lib 2> /dev/null || install -m 0755 libexample.a $(PREFIX)/lib
	mkdir -p $(PREFIX)/include
	install -o 0 -g 0 -m 0644 examples.h $(PREFIX)/include 2> /dev/null || install -m 0644 examples.h $(PREFIX)/include
	ldconfig 2> /dev/null || true